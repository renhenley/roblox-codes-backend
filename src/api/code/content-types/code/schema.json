{
  "kind": "collectionType",
  "collectionName": "codes",
  "info": {
    "singularName": "code",
    "pluralName": "codes",
    "displayName": "Code"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "code": {
      "type": "string"
    },
    "reward": {
      "type": "string"
    },
    "verificationStatus": {
      "type": "enumeration",
      "enum": [
        "working",
        "expired",
        "unverified",
        "fake"
      ]
    },
    "sourceUrl": {
      "type": "string"
    },
    "dateFound": {
      "type": "datetime"
    },
    "dateVerified": {
      "type": "datetime"
    },
    "game": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::game.game",
      "inversedBy": "codes"
    },
    "featured": {
      "type": "boolean"
    },
    "sourceType": {
      "type": "string"
    }
  }
}
